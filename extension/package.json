{
  "name": "recall",
  "displayName": "Recall",
  "description": "Click a Claude Code notification to jump back to the exact terminal — and window — it came from.",
  "version": "0.1.6",
  "publisher": "alielzei",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alielzei/recall.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#0F172A",
    "theme": "dark"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "terminal",
    "focus",
    "claude",
    "claude code",
    "notifications"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "recall.copyLink",
        "title": "Recall: Copy focus link for active terminal"
      },
      {
        "command": "recall.openDashboard",
        "title": "Recall: Open Dashboard"
      },
      {
        "command": "recall.sendTest",
        "title": "Recall: Send test notification"
      }
    ]
  }
}
